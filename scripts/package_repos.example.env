# Copy to scripts/package_repos.env and set your own targets.

# Branch where each split package history will be pushed.
TARGET_BRANCH=main

# You can use any of these formats:
# 1) git@github.com:<org>/<repo>.git
# 2) https://github.com/<org>/<repo>.git
# 3) <org>/<repo>  (requires PACKAGE_REPO_TOKEN or GITHUB_TOKEN)
AUTH_REPO_URL=
ADMIN_API_REPO_URL=
TECH_BLOG_REPO_URL=

# Optional. Used only when repository URLs are provided as <org>/<repo>.
# PACKAGE_REPO_TOKEN=
